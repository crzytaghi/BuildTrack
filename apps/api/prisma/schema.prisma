generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                   String     @id @default(uuid())
  name                 String
  timezone             String?
  companySetupComplete Boolean    @default(false)
  users                User[]
  projects             Project[]
  vendors              Vendor[]
  categories           Category[]
}

model User {
  id           String    @id
  email        String    @unique
  name         String
  passwordHash String
  passwordSalt String
  createdAt    String
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  sessions     Session[]
}

model Session {
  token     String @id
  userId    String
  expiresAt Float
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String           @id
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  name        String
  status      String           @default("planning")
  startDate   String?
  endDate     String?
  budgetTotal Float?
  notes       String?
  tasks       Task[]
  expenses    Expense[]
  lineItems   BudgetLineItem[]
  quotes      Quote[]
}

model Task {
  id        String  @id
  projectId String
  title     String
  status    String  @default("todo")
  dueDate   String?
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Category {
  id        String           @id
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  name      String
  expenses  Expense[]
  lineItems BudgetLineItem[]
}

model Vendor {
  id          String    @id
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  name        String
  trade       String?
  contactName String?
  phone       String?
  email       String?
  notes       String?
  expenses    Expense[]
  quotes      Quote[]
}

model Expense {
  id          String          @id
  projectId   String
  amount      Float
  categoryId  String
  vendorId    String
  description String
  expenseDate String
  lineItemId  String?
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category    Category        @relation(fields: [categoryId], references: [id])
  vendor      Vendor          @relation(fields: [vendorId], references: [id])
  lineItem    BudgetLineItem? @relation(fields: [lineItemId], references: [id])
}

model BudgetLineItem {
  id             String    @id
  projectId      String
  categoryId     String
  description    String
  budgetedAmount Float
  notes          String?
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category       Category  @relation(fields: [categoryId], references: [id])
  expenses       Expense[]
  quotes         Quote[]
}

model Quote {
  id          String         @id
  lineItemId  String
  projectId   String
  vendorId    String
  amount      Float
  status      String         @default("pending")
  description String?
  expiresAt   String?
  submittedAt String
  lineItem    BudgetLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor      Vendor         @relation(fields: [vendorId], references: [id])
}
